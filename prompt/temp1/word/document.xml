<?xml version="1.0" encoding="UTF-8" standalone="yes"?><w:document mc:Ignorable="w14 w15 wp14" xmlns:wpc="http://schemas.microsoft.com/office/word/2010/wordprocessingCanvas" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships" xmlns:m="http://schemas.openxmlformats.org/officeDocument/2006/math" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:wp14="http://schemas.microsoft.com/office/word/2010/wordprocessingDrawing" xmlns:wp="http://schemas.openxmlformats.org/drawingml/2006/wordprocessingDrawing" xmlns:w10="urn:schemas-microsoft-com:office:word" xmlns:w="http://schemas.openxmlformats.org/wordprocessingml/2006/main" xmlns:w14="http://schemas.microsoft.com/office/word/2010/wordml" xmlns:w15="http://schemas.microsoft.com/office/word/2012/wordml" xmlns:wpg="http://schemas.microsoft.com/office/word/2010/wordprocessingGroup" xmlns:wpi="http://schemas.microsoft.com/office/word/2010/wordprocessingInk" xmlns:wne="http://schemas.microsoft.com/office/word/2006/wordml" xmlns:wps="http://schemas.microsoft.com/office/word/2010/wordprocessingShape" xmlns:cx="http://schemas.microsoft.com/office/drawing/2014/chartex" xmlns:cx1="http://schemas.microsoft.com/office/drawing/2015/9/8/chartex" xmlns:cx2="http://schemas.microsoft.com/office/drawing/2015/10/21/chartex" xmlns:cx3="http://schemas.microsoft.com/office/drawing/2016/5/9/chartex" xmlns:cx4="http://schemas.microsoft.com/office/drawing/2016/5/10/chartex" xmlns:cx5="http://schemas.microsoft.com/office/drawing/2016/5/11/chartex" xmlns:cx6="http://schemas.microsoft.com/office/drawing/2016/5/12/chartex" xmlns:cx7="http://schemas.microsoft.com/office/drawing/2016/5/13/chartex" xmlns:cx8="http://schemas.microsoft.com/office/drawing/2016/5/14/chartex" xmlns:aink="http://schemas.microsoft.com/office/drawing/2016/ink" xmlns:am3d="http://schemas.microsoft.com/office/drawing/2017/model3d" xmlns:w16cex="http://schemas.microsoft.com/office/word/2018/wordml/cex" xmlns:w16cid="http://schemas.microsoft.com/office/word/2016/wordml/cid" xmlns:w16="http://schemas.microsoft.com/office/word/2018/wordml" xmlns:w16sdtdh="http://schemas.microsoft.com/office/word/2020/wordml/sdtdatahash" xmlns:w16se="http://schemas.microsoft.com/office/word/2015/wordml/symex"><w:body><w:p><w:pPr><w:pStyle w:val="Heading1"/><w:pStyle w:val="MdHeading1"/></w:pPr><w:r><w:t xml:space="preserve">Developer Prompt and Local Setup Guide for Hon. HASH Project</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="MdParagraph"/></w:pPr><w:r><w:t xml:space="preserve">This document contains a comprehensive prompt to provide to your developer, &quot;antigravity,&quot; to guide the next phase of updates for the Hon. HASH application. It also includes a step-by-step guide to help you set up the project locally on your machine for testing and review.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="MdSpace"/><w:spacing w:before="0" w:after="60"/></w:pPr></w:p><w:p><w:pPr><w:pStyle w:val="MdHr"/><w:pBdr><w:bottom w:val="single" w:color="auto" w:sz="6" w:space="1"/></w:pBdr></w:pPr></w:p><w:p><w:pPr><w:pStyle w:val="MdSpace"/><w:spacing w:before="0" w:after="60"/></w:pPr></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/><w:pStyle w:val="MdHeading2"/></w:pPr><w:r><w:t xml:space="preserve">Part 1: Prompt for Developer (&quot;antigravity&quot;)</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="MdParagraph"/></w:pPr><w:r><w:rPr><w:rStyle w:val="MdStrong"/><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Subject: Urgent Updates and Professionalization Plan for Hon. HASH Website</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="MdSpace"/><w:spacing w:before="0" w:after="60"/></w:pPr></w:p><w:p><w:pPr><w:pStyle w:val="MdParagraph"/></w:pPr><w:r><w:t xml:space="preserve">Hi antigravity,</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="MdSpace"/><w:spacing w:before="0" w:after="60"/></w:pPr></w:p><w:p><w:pPr><w:pStyle w:val="MdParagraph"/></w:pPr><w:r><w:t xml:space="preserve">I have a set of important updates and a broader professionalization plan for the Hon. HASH website that I need you to implement. Please review the following requirements carefully and provide an estimated timeline for completion.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="MdSpace"/><w:spacing w:before="0" w:after="60"/></w:pPr></w:p><w:p><w:pPr><w:pStyle w:val="Heading3"/><w:pStyle w:val="MdHeading3"/></w:pPr><w:r><w:t xml:space="preserve">1. Critical Bug Fix: Sticker Generator Images</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="MdParagraph"/></w:pPr><w:r><w:t xml:space="preserve">We are experiencing a critical issue with the Sticker Generator feature. When users attempt to share or download their generated stickers, the images (specifically Hon. HASH&apos;s primary photo and the supporter&apos;s uploaded image) are frequently missing or broken in the final output.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="MdSpace"/><w:spacing w:before="0" w:after="60"/></w:pPr></w:p><w:p><w:pPr><w:pStyle w:val="MdParagraph"/></w:pPr><w:r><w:rPr><w:rStyle w:val="MdStrong"/><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Technical Context &amp; Required Fixes:</w:t></w:r><w:r><w:t xml:space="preserve">
The current implementation uses </w:t></w:r><w:r><w:rPr><w:rStyle w:val="MdCode"/><w:u w:val="single"/></w:rPr><w:t xml:space="preserve">html2canvas</w:t></w:r><w:r><w:t xml:space="preserve">. The issue likely stems from Cross-Origin Resource Sharing (CORS) restrictions or image loading timing.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="MdSpace"/><w:spacing w:before="0" w:after="60"/></w:pPr></w:p><w:p><w:pPr><w:pStyle w:val="MdListItem"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r><w:rPr><w:rStyle w:val="MdStrong"/><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Implement Image Preloading:</w:t></w:r><w:r><w:t xml:space="preserve"> Ensure all dynamic images (especially the </w:t></w:r><w:r><w:rPr><w:rStyle w:val="MdCode"/><w:u w:val="single"/></w:rPr><w:t xml:space="preserve">supporterPhoto</w:t></w:r><w:r><w:t xml:space="preserve">) are fully loaded and rendered in the DOM </w:t></w:r><w:r><w:rPr><w:rStyle w:val="MdEm"/><w:i/><w:iCs/></w:rPr><w:t xml:space="preserve">before</w:t></w:r><w:r><w:t xml:space="preserve"> </w:t></w:r><w:r><w:rPr><w:rStyle w:val="MdCode"/><w:u w:val="single"/></w:rPr><w:t xml:space="preserve">html2canvas</w:t></w:r><w:r><w:t xml:space="preserve"> executes its capture.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="MdListItem"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r><w:rPr><w:rStyle w:val="MdStrong"/><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Verify CORS Configuration:</w:t></w:r><w:r><w:t xml:space="preserve"> Ensure that all image assets, whether local or hosted externally, are served with the correct CORS headers (</w:t></w:r><w:r><w:rPr><w:rStyle w:val="MdCode"/><w:u w:val="single"/></w:rPr><w:t xml:space="preserve">Access-Control-Allow-Origin</w:t></w:r><w:r><w:t xml:space="preserve">). Verify that the </w:t></w:r><w:r><w:rPr><w:rStyle w:val="MdCode"/><w:u w:val="single"/></w:rPr><w:t xml:space="preserve">crossOrigin=&quot;anonymous&quot;</w:t></w:r><w:r><w:t xml:space="preserve"> attribute is consistently and correctly applied to all relevant </w:t></w:r><w:r><w:rPr><w:rStyle w:val="MdCode"/><w:u w:val="single"/></w:rPr><w:t xml:space="preserve">&lt;img&gt;</w:t></w:r><w:r><w:t xml:space="preserve"> tags within the sticker templates.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="MdListItem"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r><w:rPr><w:rStyle w:val="MdStrong"/><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Enhance Error Handling:</w:t></w:r><w:r><w:t xml:space="preserve"> Improve the error handling in </w:t></w:r><w:r><w:rPr><w:rStyle w:val="MdCode"/><w:u w:val="single"/></w:rPr><w:t xml:space="preserve">page.tsx</w:t></w:r><w:r><w:t xml:space="preserve"> to provide users with specific, actionable feedback if image generation fails (e.g., &quot;Image failed to load. Please check your connection or try a different image.&quot;), rather than generic alerts.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="MdSpace"/><w:spacing w:before="0" w:after="60"/></w:pPr></w:p><w:p><w:pPr><w:pStyle w:val="Heading3"/><w:pStyle w:val="MdHeading3"/></w:pPr><w:r><w:t xml:space="preserve">2. Content Update: Office Addresses</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="MdParagraph"/></w:pPr><w:r><w:t xml:space="preserve">Please update the website&apos;s contact and footer sections to accurately reflect Hon. HASH&apos;s official titles and office addresses.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="MdSpace"/><w:spacing w:before="0" w:after="60"/></w:pPr></w:p><w:p><w:pPr><w:pStyle w:val="MdParagraph"/></w:pPr><w:r><w:rPr><w:rStyle w:val="MdStrong"/><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">New Information to Add:</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="MdListItem"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r><w:rPr><w:rStyle w:val="MdStrong"/><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Title:</w:t></w:r><w:r><w:t xml:space="preserve"> Member House of Representatives Nassarawa Federal Constituency, Kano State</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="MdListItem"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r><w:rPr><w:rStyle w:val="MdStrong"/><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Additional Title:</w:t></w:r><w:r><w:t xml:space="preserve"> DEPUTY CHAIRMAN HOUSE COMMITTEE ON CUSTOMS AND EXCISE</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="MdListItem"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r><w:rPr><w:rStyle w:val="MdStrong"/><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Constituency Office Venue:</w:t></w:r><w:r><w:t xml:space="preserve"> Gadar Tudun Murtala, opposite sheikh Ja&apos;afar Mosque, Tudun Murtala, Nassarawa Local Government Area, Kano State.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="MdSpace"/><w:spacing w:before="0" w:after="60"/></w:pPr></w:p><w:p><w:pPr><w:pStyle w:val="Heading3"/><w:pStyle w:val="MdHeading3"/></w:pPr><w:r><w:t xml:space="preserve">3. Strategic Professionalization Plan (Phase 2 &amp; 3)</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="MdParagraph"/></w:pPr><w:r><w:t xml:space="preserve">We are moving forward with a comprehensive plan to elevate the website into a &quot;portfolio masterpiece.&quot; Please begin implementing the following phases:</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="MdSpace"/><w:spacing w:before="0" w:after="60"/></w:pPr></w:p><w:p><w:pPr><w:pStyle w:val="MdParagraph"/></w:pPr><w:r><w:rPr><w:rStyle w:val="MdStrong"/><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Phase 2: Migration &amp; Core Development</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="MdListItem"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r><w:rPr><w:rStyle w:val="MdStrong"/><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Database Migration:</w:t></w:r><w:r><w:t xml:space="preserve"> Migrate the current backend from MongoDB Atlas + Sanity to </w:t></w:r><w:r><w:rPr><w:rStyle w:val="MdStrong"/><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Supabase</w:t></w:r><w:r><w:t xml:space="preserve"> (PostgreSQL + Auth + Realtime + Storage). This is a priority for better scalability and real-time capabilities.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="MdListItem"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r><w:rPr><w:rStyle w:val="MdStrong"/><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Admin Dashboard:</w:t></w:r><w:r><w:t xml:space="preserve"> Develop a dynamic, secure Admin Dashboard using Supabase Auth for CRUD operations on all content (projects, media gallery, news, supporters).</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="MdSpace"/><w:spacing w:before="0" w:after="60"/></w:pPr></w:p><w:p><w:pPr><w:pStyle w:val="MdParagraph"/></w:pPr><w:r><w:rPr><w:rStyle w:val="MdStrong"/><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Phase 3: Polish &amp; Professional Features</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="MdListItem"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r><w:rPr><w:rStyle w:val="MdStrong"/><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">SEO &amp; Analytics:</w:t></w:r><w:r><w:t xml:space="preserve"> Implement comprehensive SEO best practices (dynamic meta tags, sitemap.xml, JSON-LD) and integrate Google Analytics 4 and Vercel Analytics.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="MdListItem"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r><w:rPr><w:rStyle w:val="MdStrong"/><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">&quot;Forgotten Aspects&quot;:</w:t></w:r><w:r><w:t xml:space="preserve"> Ensure the following often-overlooked elements are implemented:</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="MdListItem"/><w:numPr><w:ilvl w:val="1"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r><w:t xml:space="preserve">Favicon &amp; Apple Touch Icon</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="MdListItem"/><w:numPr><w:ilvl w:val="1"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r><w:t xml:space="p